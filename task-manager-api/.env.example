# Copie para `.env` e ajuste. Nunca comite o `.env` com segredos reais.

# Flask
SECRET_KEY=troque-esta-chave
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# Banco de dados (SQLite por padrão)
DB_PATH=tasks.db
# Alternativamente, uma URL completa: DATABASE_URL=sqlite:///tasks.db

# SMTP (serviço de notificação por e-mail) — opcional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
