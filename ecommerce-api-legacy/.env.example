# Exemplo de variáveis de ambiente. Copie para `.env` e preencha em produção.
# NUNCA comite segredos reais.

PORT=3000
APP_NAME=LMS API

# Caminho do banco SQLite. Use ":memory:" para banco em memória (default de dev).
DB_PATH=:memory:

# Chave do gateway de pagamento (ex.: pk_live_...). Obrigatória em produção.
PAYMENT_GATEWAY_KEY=

# Usuário SMTP para envio de e-mails transacionais.
SMTP_USER=
